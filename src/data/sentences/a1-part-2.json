  {
    "id": "a1-part-2-23",
    "ru": "Я не замужем.",
    "ruStressed": "Я не за́мужем.",
    "translit": "Ya ne zamuzhem.",
    "en": "I'm not married. (f.)",
    "pl": "Nie jestem zamężna. (f.)"
  },
  {
    "id": "a1-part-2-24",
    "ru": "Один, два, три.",
